# AquaLabel — .gitignore

# ── OS Files ──────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ──────────────────────
.vscode/
.idea/
*.sublime-workspace
*.code-workspace

# ── Logs ──────────────────────────────
*.log
npm-debug.log*

# ── Node (if ever added for tooling) ──
node_modules/
package-lock.json
yarn.lock

# ── Build artifacts ────────────────────
dist/
build/

# ── Local config / secrets ─────────────
.env
.env.local
.env.*.local

# ── Temp files ─────────────────────────
*.tmp
*.bak
*.swp
*~
